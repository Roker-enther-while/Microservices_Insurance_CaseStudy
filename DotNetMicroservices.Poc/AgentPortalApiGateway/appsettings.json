{
  "Logging": {
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Trace",
      "System": "Information",
      "Microsoft": "Information",
      "Newtonsoft": "Information"
    }
  },

  "spring": {
    "application": {
      "name": "Agent-Portal-Api-Gateway"
    }
  },

  "eureka": {
    "client": {
      "serviceUrl": "http://localhost:8761/eureka/",
      "shouldRegisterWithEureka": false,
      "validateCertificates": false
    }
  },

  "AppSettings": {
    "AllowedChatOrigins": [
      "http://localhost:8080",
      "http://localhost",
      "http://localhost:5081"
    ]
  }
}